#!/bin/sh

commit_msg=$(cat "$1")
pattern="^(feat|fix|docs|style|refactor|test|chore|build|ci|perf|revert)(\(.+\))?!?: .{1,72}$"

if ! echo "$commit_msg" | grep -qE "$pattern"; then
  echo ""
  echo "  ✖ Invalid commit message format."
  echo ""
  echo "  Expected : <type>(<scope>): <description>"
  echo "  Example  : feat(auth): add JWT login"
  echo ""
  echo "  Types:"
  echo "    feat      A new feature"
  echo "    fix       A bug fix"
  echo "    docs      Documentation changes"
  echo "    style     Formatting, missing semicolons, etc."
  echo "    refactor  Code refactoring"
  echo "    test      Adding or updating tests"
  echo "    chore     Build process or tooling changes"
  echo "    build     Changes affecting the build system"
  echo "    ci        CI/CD configuration changes"
  echo "    perf      Performance improvements"
  echo "    revert    Reverting a previous commit"
  echo ""
  echo "  Your message: \"$commit_msg\""
  echo ""
  exit 1
fi
